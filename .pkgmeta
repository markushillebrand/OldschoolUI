package-as: OldschoolUI

enable-nolib-creation: no

ignore:
  - OUI_Probe
  - dev

# Suite modules ship as sibling top-level folders in the final zip.
move-folders:
  OldschoolUI/OUI_ActionBars: OUI_ActionBars
  OldschoolUI/OUI_AuraBuffReminders: OUI_AuraBuffReminders
  OldschoolUI/OUI_Bags: OUI_Bags
  OldschoolUI/OUI_BlizzardSkin: OUI_BlizzardSkin
  OldschoolUI/OUI_Chat: OUI_Chat
  OldschoolUI/OUI_DamageMeter: OUI_DamageMeter
  OldschoolUI/OUI_Friends: OUI_Friends
  OldschoolUI/OUI_GroupTimer: OUI_GroupTimer
  OldschoolUI/OUI_LootRoll: OUI_LootRoll
  OldschoolUI/OUI_Minimap: OUI_Minimap
  OldschoolUI/OUI_Nameplates: OUI_Nameplates
  OldschoolUI/OUI_QoL: OUI_QoL
  OldschoolUI/OUI_QuestTracker: OUI_QuestTracker
  OldschoolUI/OUI_RaidFrames: OUI_RaidFrames
  OldschoolUI/OUI_ResourceBars: OUI_ResourceBars
  OldschoolUI/OUI_UnitFrames: OUI_UnitFrames
